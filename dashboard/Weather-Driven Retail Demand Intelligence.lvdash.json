            "displayName": "Category Focus"
          },
          {
            "name": "rain_gear_demand",
            "expr": "source.rain_gear_demand",
            "displayName": "Rain Gear Demand"
          },
          {
            "name": "ac_cooling_demand",
            "expr": "source.ac_cooling_demand",
            "displayName": "Ac Cooling Demand"
          },
          {
            "name": "outdoor_event_risk",
            "expr": "source.outdoor_event_risk",
            "displayName": "Outdoor Event Risk"
          },
          {
            "name": "staffing_recommendation",
            "expr": "source.staffing_recommendation",
            "displayName": "Staffing Recommendation"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    },
    {
      "name": "46f4bb04",
      "displayName": "Retail Weather Impact On Store Demand Data",
      "queryLines": [
        "SELECT\n",
        "  store_id,\n",
        "  city,\n",
        "  region,\n",
        "  observation_time,\n",
        "  temperature_f,\n",
        "  precipitation_in,\n",
        "  ac_cooling_demand,\n",
        "  rain_gear_demand\n",
        "FROM\n",
        "  retail_demo.retail_gold.demand_signal_history\n",
        "ORDER BY\n",
        "  observation_time"
      ]
    },
    {
      "name": "forecast_planner",
      "displayName": "14-Day Staffing Forecast Data",
      "queryLines": [
        "SELECT\n",
        "  store_id,\n",
        "  city,\n",
        "  region,\n",
        "  forecast_date,\n",
        "  staffing_recommendation,\n",
        "  temp_max_f,\n",
        "  precip_prob_pct\n",
        "FROM\n",
        "  retail_demo.retail_gold.demand_signal_forecast\n",
        "ORDER BY\n",
        "  forecast_date,\n",
        "  store_id"
      ]
    },
    {
      "name": "region_temp_avg",
      "displayName": "Regional Temperature Averages",
      "queryLines": [
        "SELECT\n",
        "  region,\n",
        "  observation_time,\n",
        "  AVG(temperature_f) AS avg_temp_f\n",
        "FROM\n",
        "  retail_demo.retail_gold.demand_signal_history\n",
        "GROUP BY\n",
        "  region,\n",
        "  observation_time\n",
        "ORDER BY\n",
        "  observation_time"
      ]
    }
  ],
